{
  "name": "@agentform/schema",
  "version": "0.1.0",
  "private": true,
  "description": "Agentform specification schema — Zod schemas and generated JSON Schema for v1alpha1.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "generate:json-schema": "node scripts/generate-json-schema.mjs"
  },
  "dependencies": {
    "@agentform/diagnostics": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "yaml": "^2.9.0"
  }
}
