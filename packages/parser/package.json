{
  "name": "@agentform/parser",
  "version": "0.1.0",
  "private": true,
  "description": "Agentform source parser — YAML/JSON loading, references, and variable interpolation.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentform/core": "workspace:*",
    "@agentform/diagnostics": "workspace:*",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1"
  }
}
