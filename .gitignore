# Dependencies
node_modules/

# Build outputs
dist/
build/
.turbo/
coverage/

# Agentform local state and generated artifacts
.agentform/
*.afplan
generated/

# Release artifacts (regenerated fresh per release, not committed — a
# checked-in SBOM would silently drift from the dependency graph it's
# supposed to describe the moment any dependency changes)
/sbom.json

# Environment variables
.env
.env.*
!.env.example

# Logs
*.log

# Temporary files
temp/
*.tmp

# macOS system files
.DS_Store
.AppleDouble
.lsdheaders
.Spotlight-V100
.Trashes

# Editors
.vscode/*
!.vscode/extensions.json
.idea/
